#!/bin/bash
# run_once_after_50-setup-claude-mcp.sh.tmpl
# Runs once after chezmoi apply to set up Claude MCP servers

set -e

echo "Setting up Claude Code MCP servers..."

{{ if .minimal | default false }}
echo "Skipping Claude setup (minimal install)"
exit 0
{{ end }}

if ! command -v claude >/dev/null 2>&1; then
    echo "Claude CLI not installed, skipping MCP setup"
    exit 0
fi

{{ if .claude_mcp | default true }}

add_mcp() {
    local name="$1"
    shift
    if claude mcp list 2>/dev/null | grep -q "$name"; then
        echo "  $name already configured"
    else
        if claude mcp add -s user "$name" "$@"; then
            echo "  + $name added"
        else
            echo "  ! $name failed to add" >&2
        fi
    fi
}

# Codegraph - code knowledge graph
add_mcp codegraph -- codegraph serve --mcp

# Context7 - library docs
add_mcp context7 -- npx -y @upstash/context7-mcp

{{ else }}
echo "Skipping MCP setup (claude_mcp = false)"
{{ end }}

echo "Claude MCP setup complete"
