{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agentPushNotifEnabled": false,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "autoDreamEnabled": false,
  "autoMemoryEnabled": false,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "agentmemory@agentmemory": true,
    "claude-hud@claude-hud": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_EXPERIMENTAL_MCP_CLI": "1",
    "AGENTMEMORY_SECRET": "",
    "AGENTMEMORY_URL": "http://localhost:3113",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1"
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "git",
        "url": "https://github.com/jarrodwatts/claude-hud.git"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm run:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(source:*)",
      "Bash(tail:*)",
      "Read(~/.zshrc)",
      "WebFetch(domain:*)",
      "WebSearch",
      "Write",
      "mcp__context7",
      "mcp__codegraph__codegraph_search",
      "mcp__codegraph__codegraph_context",
      "mcp__codegraph__codegraph_callers",
      "mcp__codegraph__codegraph_callees",
      "mcp__codegraph__codegraph_impact",
      "mcp__codegraph__codegraph_node",
      "mcp__codegraph__codegraph_status",
      "mcp__codegraph__codegraph_files"
    ],
    "defaultMode": "plan",
    "deny": []
  },
  "plansDirectory": ".claude/plans",
  "remoteControlAtStartup": false,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "node $(ls -td $HOME/.claude/plugins/cache/claude-hud/claude-hud/*/ 2\u003e/dev/null | head -1)dist/index.js",
    "type": "command"
  },
  "teammateMode": "auto",
  "tui": "fullscreen",
  "verbose": true
}
