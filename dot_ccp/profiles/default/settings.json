{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_EXPERIMENTAL_MCP_CLI": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm run:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(source:*)",
      "Bash(tail:*)",
      "Read(~/.zshrc)",
      "WebFetch(domain:*)",
      "WebSearch",
      "Write",
      "mcp__context7",
      "mcp__codebase__index_repository",
      "mcp__codebase__search_graph",
      "mcp__codebase__query_graph",
      "mcp__codebase__trace_path",
      "mcp__codebase__get_code_snippet",
      "mcp__codebase__get_graph_schema",
      "mcp__codebase__get_architecture",
      "mcp__codebase__search_code",
      "mcp__codebase__list_projects",
      "mcp__codebase__index_status",
      "mcp__codebase__detect_changes",
      "mcp__codebase__manage_adr"
    ],
    "deny": [],
    "defaultMode": "plan"
  },
  "model": "sonnet",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.ccp/profiles/default/hooks/surgical-changes/scripts/surgical-changes-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.ccp/profiles/default/hooks/session-start/scripts/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.ccp/profiles/default/hooks/codebase-remind/scripts/codebase-remind.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.ccp/profiles/default/hooks/doc-rules/scripts/check-doc-rules.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.ccp/profiles/default/hooks/force-agent-skills-eval/scripts/force-agent-skills-eval.sh",
            "timeout": 220
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node $(ls -td $HOME/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js"
  },
  "enabledPlugins": {
    "agentmemory@agentmemory": true,
    "claude-hud@claude-hud": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "understand-anything@understand-anything": true,
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "git",
        "url": "https://github.com/jarrodwatts/claude-hud.git"
      }
    },
    "understand-anything": {
      "source": {
        "source": "github",
        "repo": "Lum1104/Understand-Anything"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "effortLevel": "xhigh",
  "plansDirectory": ".claude/plans",
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "autoDreamEnabled": false,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "verbose": true,
  "teammateMode": "auto",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": false
}
