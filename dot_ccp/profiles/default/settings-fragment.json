{
  "enabledPlugins": {
    "ponytail@ponytail": false
  },
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "repo": "DietrichGebert/ponytail",
        "source": "github"
      }
    }
  },
  "inputNeededNotifEnabled": true,
  "model": "claude-fable-5[1m]",
  "permissions": {
    "defaultMode": "auto"
  },
  "remoteControlAtStartup": true,
  "skipWorkflowUsageWarning": true,
  "worktree": {
    "baseRef": "head"
  }
}
