{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "ENABLE_EXPERIMENTAL_MCP_CLI": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(echo:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm run:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(source:*)",
      "Bash(tail:*)",
      "Read(~/.zshrc)",
      "WebFetch(domain:*)",
      "WebSearch",
      "Write",
      "mcp__context7"
    ],
    "deny": [],
    "defaultMode": "plan"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.ccp/profiles/default/hooks/session-start/scripts/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.ccp/profiles/default/hooks/force-agent-skills-eval/scripts/force-agent-skills-eval.sh",
            "timeout": 220
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node $(ls -td $HOME/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "understand-anything@understand-anything": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "git",
        "url": "https://github.com/jarrodwatts/claude-hud.git"
      }
    },
    "understand-anything": {
      "source": {
        "source": "github",
        "repo": "Lum1104/Understand-Anything"
      }
    }
  },
  "effortLevel": "xhigh",
  "plansDirectory": ".claude/plans",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "verbose": true,
  "teammateMode": "auto",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": false
}
